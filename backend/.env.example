# ---- Server ----
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# ---- PostgreSQL (required) ----
# e.g. postgres://user:password@localhost:5432/fitquest
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fitquest

# ---- OTP (optional) ----
# When MSG91 is unset, the dev fixed OTP 123456 is accepted.
MSG91_AUTH_KEY=
MSG91_SENDER_ID=FITQST
DEV_FIXED_OTP=123456

# ---- Razorpay (optional) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- Claude vision for meal photos (optional) ----
# When unset, /meals/analyze returns a deterministic mock result.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
