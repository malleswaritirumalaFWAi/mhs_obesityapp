# ---- Server ----
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# ---- PostgreSQL (required) ----
# e.g. postgres://user:password@localhost:5432/fitquest
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fitquest

# ---- OTP (optional) ----
# When MSG91 is unset, the dev fixed OTP 123456 is accepted.
MSG91_AUTH_KEY=
MSG91_SENDER_ID=FITQST
DEV_FIXED_OTP=123456

# ---- Razorpay (optional) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- Claude AI (optional) ----
# When ANTHROPIC_API_KEY is unset, /meals/analyze returns a deterministic mock result.
ANTHROPIC_API_KEY=
# Model used for chat/coach responses (Sonnet recommended for quality).
ANTHROPIC_MODEL=claude-sonnet-4-6
# Model used for meal image analysis. Haiku is recommended here — it has
# 10× higher rate limits than Sonnet at 1/20th the cost, and is fully
# capable of food identification. Override with Sonnet if richer output needed.
MEAL_ANALYSIS_MODEL=claude-haiku-4-5-20251001